-- DATA PERSISTENCE LAYER
local function loadSavedData()
    local defaultData = {
        ["Universal knees"] = nil,
        ["Universal surrender"] = nil,
        ["Man wait"] = nil,
        ["man tuff"] = nil
    }
    if readfile then
        local success, content = pcall(readfile, FILE_NAME)
        if success and content then
            local decodedSuccess, decoded = pcall(function() return HttpService:JSONDecode(content) end)
            if decodedSuccess then return decoded end
        end
    end
    return defaultData
end

local function saveToStorage(data)
    if writefile then
        pcall(writefile, FILE_NAME, HttpService:JSONEncode(data))
    end
end

