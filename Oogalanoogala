OverrideToggle.MouseButton1Click:Connect(function()
    local char = getCharacter()
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local animateScript = char:FindFirstChild("Animate")
    overridesActive = not overridesActive
    
    if overridesActive then
        OverrideToggle.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
        OverrideToggle.Text = "Override Anims: ON"
        if humanoid then
            for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do track:Stop(0.1) end
        end
        if animateScript then
            for _, val in pairs(animateScript:GetChildren()) do
                if val:IsA("StringValue") then
                    originalAnims[val.Name] = {}
                    for _, anim in pairs(val:GetChildren()) do
                        if anim:IsA("Animation") then
                            originalAnims[val.Name][anim.Name] = anim.AnimationId
                            anim.AnimationId = ""
                        end
                    end
                end
            end
        end
    else
        OverrideToggle.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        OverrideToggle.Text = "Override Anims: OFF"
        if animateScript then
            for _, val in pairs(animateScript:GetChildren()) do
                if val:IsA("StringValue") and originalAnims[val.Name] then
                    for _, anim in pairs(val:GetChildren()) do
                        if anim:IsA("Animation") and originalAnims[val.Name][anim.Name] then
                            anim.AnimationId = originalAnims[val.Name][anim.Name]
                        end
                    end
                end
            end
        end
    end
end)
