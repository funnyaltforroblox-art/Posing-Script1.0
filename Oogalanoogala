-- 3. INTERACTIVE 3D MANIPULATION HANDLES WITH CAMERA LOCK
-- ==========================================
local function lockCamera()
    Camera.CameraType = Enum.CameraType.Scriptable
end

local function unlockCamera()
    Camera.CameraType = Enum.CameraType.Custom
end

function update3DHandles()
    if active3DHandle then active3DHandle:Destroy() active3DHandle = nil end
    if not selectedLimbName then return end
    local char = getCharacter()
    local targetLimb = char:FindFirstChild(selectedLimbName)
    if not targetLimb or not targetLimb:IsA("BasePart") then return end

    local motor = targetLimb:FindFirstChildOfClass("Motor6D") or char.Torso:FindFirstChild(targetLimb.Name .. "Joint")

    if currentToolMode == "Rotate" then
        local arcs = Instance.new("ArcHandles")
        arcs.Color3 = Color3.fromRGB(0, 255, 255)
        arcs.Adornee = targetLimb
        arcs.Parent = ScreenGui
        active3DHandle = arcs

        local startC0 = nil
        arcs.MouseButton1Down:Connect(function() 
            if motor then 
                startC0 = motor.C0 
                lockCamera() -- Prevents camera pan on drag begin
            end 
        end)
        
        arcs.MouseButton1Up:Connect(unlockCamera) -- Restores panning on drop

        arcs.MouseAxisChanged:Connect(function(axis, relativeAngle)
            if motor and startC0 then
                if axis == Enum.Axis.X then motor.C0 = startC0 * CFrame.Angles(relativeAngle, 0, 0)
                elseif axis == Enum.Axis.Y then motor.C0 = startC0 * CFrame.Angles(0, relativeAngle, 0)
                elseif axis == Enum.Axis.Z then motor.C0 = startC0 * CFrame.Angles(0, 0, relativeAngle) end
            end
        end)
        
    elseif currentToolMode == "Move" then
        local arrows = Instance.new("Handles")
        arrows.Color3 = Color3.fromRGB(0, 180, 255)
        arrows.Style = Enum.HandlesStyle.Movement
        arrows.Adornee = targetLimb
        arrows.Parent = ScreenGui
        active3DHandle = arrows

        local startC0 = nil
        arrows.MouseButton1Down:Connect(function() 
            if motor then 
                startC0 = motor.C0 
                lockCamera() -- Prevents camera pan on drag begin
            end 
        end)
        
        arrows.MouseButton1Up:Connect(unlockCamera) -- Restores panning on drop

        arrows.MouseDrag:Connect(function(face, distance)
            if motor and startC0 then
                motor.C0 = startC0 * CFrame.new(Vector3.FromNormalId(face) * distance)
            end
        end)
    end
end

