    local sortedNames = {"Universal knees", "Universal surrender", "Man wait", "man tuff"}
    for _, name in pairs(sortedNames) do
        local dataExists = poseDatabase[name] ~= nil

        local SlotFrame = Instance.new("Frame")
        SlotFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        SlotFrame.Parent = GridContainer
        local sfCorner = Instance.new("UICorner") sfCorner.CornerRadius = UDim.new(0, 12) sfCorner.Parent = SlotFrame

        local VisualBox = Instance.new("Frame")
        VisualBox.Size = UDim2.new(1, -20, 0, 75)
        VisualBox.Position = UDim2.new(0, 10, 0, 10)
        VisualBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        VisualBox.Parent = SlotFrame
        local vbCorner = Instance.new("UICorner") vbCorner.CornerRadius = UDim.new(0, 8) vbCorner.Parent = VisualBox

        local InnerLabel = Instance.new("TextLabel")
        InnerLabel.Size = UDim2.new(1, 0, 1, 0)
        InnerLabel.BackgroundTransparency = 1
        InnerLabel.Text = dataExists and "Pose Active" or "[Empty]"
        InnerLabel.TextColor3 = dataExists and Color3.fromRGB(100, 150, 100) or Color3.fromRGB(100, 100, 100)
        InnerLabel.Font = Enum.Font.SourceSansItalic
        InnerLabel.TextSize = 12
        InnerLabel.Parent = VisualBox

        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(1, -10, 0, 35)
        NameLabel.Position = UDim2.new(0, 10, 1, -40)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Text = name
        NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        NameLabel.Font = Enum.Font.SourceSansBold
        NameLabel.TextSize = 13
        NameLabel.TextWrapped = true
        NameLabel.Parent = SlotFrame

        local ActButton = Instance.new("TextButton")
        ActButton.Size = UDim2.new(1, 0, 1, 0)
        ActButton.BackgroundTransparency = 1
        ActButton.Text = ""
        ActButton.Parent = SlotFrame

        ActButton.MouseButton1Click:Connect(function()
            if poseDatabase[name] then
                applySerializedPose(poseDatabase[name])
                update3DHandles()
            else
                poseDatabase[name] = serializePose()
                saveToStorage(poseDatabase)
                renderPresetGrid()
            end
        end)

        ActButton.MouseButton2Click:Connect(function()
            poseDatabase[name] = serializePose()
            saveToStorage(poseDatabase)
            renderPresetGrid()
        end)
    end
end

