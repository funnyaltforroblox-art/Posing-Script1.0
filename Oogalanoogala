local function serializePose()
    local poseData = {}
    local char = getCharacter()
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            local motor = part:FindFirstChildOfClass("Motor6D") or char.Torso:FindFirstChild(part.Name .. "Joint")
            if motor then
                local x, y, z = motor.C0:ToEulerAnglesXYZ()
                poseData[part.Name] = {
                    Pos = {motor.C0.X, motor.C0.Y, motor.C0.Z},
                    Rot = {x, y, z}
                }
            end
        end
    end
    return poseData
end

local function applySerializedPose(poseData)
    if not poseData then return end
    local char = getCharacter()
    for limbName, data in pairs(poseData) do
        local part = char:FindFirstChild(limbName)
        if part then
            local motor = part:FindFirstChildOfClass("Motor6D") or char.Torso:FindFirstChild(part.Name .. "Joint")
            if motor then
                motor.C0 = CFrame.new(unpack(data.Pos)) * CFrame.Angles(unpack(data.Rot))
            end
        end
    end
end

